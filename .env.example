# Copy to ".env" and adjust. docker-compose reads these automatically.
# NEVER commit the real .env file.

# SQL Server SA password (must satisfy SQL Server complexity rules)
MSSQL_SA_PASSWORD=Your_strong_Pass123

# JWT signing key — use a long random secret (>= 32 chars) in real deployments
JWT_KEY=local-dev-only-change-me-to-a-long-random-secret-32+
